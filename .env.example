# Supabase (proiect local: valorile din `supabase start`)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# URL public al site-ului (folosit pentru redirect-ul de confirmare email)
# `npm run dev` rulează fix pe portul 3001 (vezi package.json) — păstrează-l sincron aici.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Token bearer pentru POST /api/agent-report (rutina Claude programată,
# skill "schedule" — trimite draft-uri de rapoarte, nu importă direct).
# Generează cu: openssl rand -hex 32 (sau node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
AGENT_REPORT_TOKEN=

# Email tranzacțional (M3) — cheia din contul Resend al beneficiarului
RESEND_API_KEY=

# Token bearer pentru GET /api/cron/notifications (Vercel Cron, vezi vercel.json).
# Vercel adaugă automat Authorization: Bearer $CRON_SECRET la apelurile cron
# dacă variabila e setată — aceeași valoare trebuie pusă și aici.
CRON_SECRET=

# Stripe (M4)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# Afiliere verificare istoric VIN (M4, opțional) — ID-urile programelor de
# afiliat carVertical/autoDNA; fără ele, linkurile duc la paginile publice.
NEXT_PUBLIC_AFFILIATE_CARVERTICAL=
NEXT_PUBLIC_AFFILIATE_AUTODNA=

# AdSense (M4, opțional) — client ID (ca-pub-...); scriptul se încarcă DOAR
# după consimțământul cookie (GDPR-03). Fără el, sloturile rămân placeholder.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# AI (opțional, M3)
ANTHROPIC_API_KEY=
